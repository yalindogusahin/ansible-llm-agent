---
# ansible_ai_rules is intentionally a top-level (global) variable, not a role-scoped one,
# so the no-role-prefix rule does not apply.
#
# replace-urlopen is allow-listed in tests/sanity/ignore-*.txt because llm_client.py
# is also imported by the eval harness (tests/eval) and must not depend on
# ansible.module_utils.urls.open_url (which requires an AnsibleModule context).
skip_list:
  - var-naming[no-role-prefix]
  - sanity[cannot-ignore]

exclude_paths:
  - .git/
  - .venv/
  - .pytest_cache/
  - tests/integration/inventory.ini
  # ansible-lint runs in its own venv and cannot resolve the FQCN of the
  # collection being linted (chicken-and-egg). The integration playbook uses
  # yalindogusahin.ansible_ai.ai_agent which is the very collection ansible-lint
  # is operating on. syntax-check is an unskippable rule, so we exclude the
  # file instead. ansible-playbook --syntax-check still validates it during CI.
  - tests/integration/playbook_debug.yml
  - tests/integration/playbook_localhost_smoke.yml
  # tests/eval/fixtures/*.yaml are scripted-LLM eval test data (synthetic
  # tool stdout/stderr inline), not ansible playbooks. Long lines are
  # intentional - they hold raw command output the agent is expected to parse.
  - tests/eval/fixtures/
  # changelogs/changelog.yaml is generated by antsibull-changelog from per-PR
  # fragments. Release-note lines come straight from commit subjects; rewrapping
  # locally would be undone on the next release run.
  - changelogs/changelog.yaml
